# App
NEXT_PUBLIC_SITE_URL=https://dreamtourism.it
NODE_ENV=production

# Payload CMS
PAYLOAD_SECRET=your-payload-secret-min-32-chars
# Local Homebrew Postgres (macOS default user = your OS username):
# DATABASE_URI=postgresql://YOUR_USERNAME@localhost:5432/dreamtourism
# Neon production:
DATABASE_URI=postgresql://user:password@host.neon.tech/dreamtourism?sslmode=require

# Bókun API
BOKUN_ACCESS_KEY=your-bokun-access-key
BOKUN_SECRET_KEY=your-bokun-secret-key
BOKUN_BASE_URL=https://api.bokun.io
BOKUN_CURRENCY=EUR
BOKUN_LANG=EN
BOKUN_WEBHOOK_SECRET=your-bokun-webhook-secret

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Resend Email
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=bookings@dreamtourism.it

# Cache
CACHE_TTL_SECONDS=60

# Cloudflare R2 (media uploads)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
